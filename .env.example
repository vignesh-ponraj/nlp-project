# =============================================================================
# PivotDrift — copy to backend/.env when running the API locally (see README)
# =============================================================================

# --- Azure AI Translator (required for translation) ---
# https://azure.microsoft.com/products/ai-services/translator/
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=eastus
# Optional: override for dedicated resource (default global endpoint below)
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# --- Embeddings: openai | gemini ---
EMBEDDING_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Google AI Studio (https://aistudio.google.com/apikey) — set EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- API server ---
# Comma-separated browser origins allowed to call the API (CORS)
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_INPUT_CHARS=800
