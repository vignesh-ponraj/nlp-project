# =============================================================================
# PivotDrift — copy to backend/.env when running the API locally (see README)
# =============================================================================

# --- Translation (LLM via subscription you already have) ---
# openai = OpenAI Chat Completions (same API key as embeddings if you use OpenAI embeddings)
# anthropic = Anthropic Messages API (Claude)
TRANSLATION_PROVIDER=openai
OPENAI_TRANSLATION_MODEL=gpt-4o-mini

# Anthropic — required only if TRANSLATION_PROVIDER=anthropic
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_TRANSLATION_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# --- Embeddings: openai | gemini ---
EMBEDDING_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Google AI Studio (https://aistudio.google.com/apikey) — set EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- API server ---
# Comma-separated browser origins allowed to call the API (CORS)
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_INPUT_CHARS=800
